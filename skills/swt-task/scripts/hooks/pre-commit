#!/bin/bash
# .git/hooks/pre-commit
# SWT: Physical Gate for Taskless Commits
# This hook blocks commits when no SWT task is active (task.ctx is empty).

ROOT_DIR=$(git rev-parse --show-toplevel)
TASK_CTX="$ROOT_DIR/task.ctx"

# EXEMPTION: If ALL staged files are sidecar artifacts (.tasks/ or .specs/), allow the commit.
STAGED_FILES=$(git diff --cached --name-only)
NON_SIDECAR_FILES=$(echo "$STAGED_FILES" | grep -vE "^(\.tasks/|\.specs/)" || true)

if [ -z "$NON_SIDECAR_FILES" ]; then
    # Only sidecars are staged, allow commit (likely a phase transition or sync)
    exit 0
fi

if [ ! -s "$TASK_CTX" ]; then
    echo ""
    echo "🛑 TASKLESS COMMIT BLOCKED"
    echo "   You are attempting to commit source changes with no active SWT task."
    echo ""
    echo "👉 How to fix:"
    echo "   1. Create a task: /swt:flow brainstorm \"topic\""
    echo "   2. Mount a task:  /swt:flow mount <task_file>"
    echo ""
    echo "   Wait! If you are sure you want to bypass this gate, use 'git commit --no-verify'."
    echo ""
    exit 1
fi

exit 0
